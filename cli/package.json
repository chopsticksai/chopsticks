{
  "name": "@runeachai/runeach",
  "version": "0.3.1",
  "description": "RunEach CLI — orchestrate AI agent teams to run a business",
  "type": "module",
  "bin": {
    "runeach": "./dist/index.js"
  },
  "keywords": [
    "runeach",
    "ai",
    "agents",
    "orchestration",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/runeachai/runeach.git",
    "directory": "cli"
  },
  "homepage": "https://github.com/runeachai/runeach",
  "bugs": {
    "url": "https://github.com/runeachai/runeach/issues"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "node ./scripts/build.mjs",
    "clean": "node ./scripts/clean.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "@runeachai/adapter-claude-local": "workspace:*",
    "@runeachai/adapter-codebuddy-local": "workspace:*",
    "@runeachai/adapter-codex-local": "workspace:*",
    "@runeachai/adapter-cursor-local": "workspace:*",
    "@runeachai/adapter-gemini-local": "workspace:*",
    "@runeachai/adapter-opencode-local": "workspace:*",
    "@runeachai/adapter-pi-local": "workspace:*",
    "@runeachai/adapter-openclaw-gateway": "workspace:*",
    "@runeachai/adapter-utils": "workspace:*",
    "@runeachai/db": "workspace:*",
    "@runeachai/server": "workspace:*",
    "@runeachai/shared": "workspace:*",
    "drizzle-orm": "0.38.4",
    "dotenv": "^17.0.1",
    "commander": "^13.1.0",
    "embedded-postgres": "^18.1.0-beta.16",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
